// © Hin + Claude
// Strategy-Picker v2.1 — Triple Screen: 5m / 15m / 60m
// Score-based TF state (3-of-4 signals). EMA 8 position.
// Time-based alerts: 6:30 AM PT fixed, 7:00 AM PT optional.
// All alerts output plain-text (no JSON — paste into TradingView alert Message field as-is).
// Webhook: set TradingView alert Message field to BLANK so alert() text passes through cleanly.

//@version=6
indicator("Strategy-Picker v2.1", overlay=false, max_lines_count=200, max_labels_count=200)

// ═══════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════

fastLen    = input.int(12,  "MACD Fast Length",   minval=1,   group="MACD / EMA")
slowLen    = input.int(26,  "MACD Slow Length",   minval=1,   group="MACD / EMA")
sigLen     = input.int(9,   "MACD Signal Length", minval=1,   group="MACD / EMA")
emaLen     = input.int(8,   "EMA Length",         minval=1,   group="MACD / EMA")

adxLen     = input.int(14,  "ADX Length",         minval=1,   group="ADX")
adxTrendTh = input.float(20,"ADX Trend Threshold",            group="ADX")
scoreTh    = input.int(3,   "TF Bull/Bear Score Threshold (of 4)", minval=2, maxval=4, group="ADX",
             tooltip="How many of 4 signals (MACD>0, MACD>Signal, Close>EMA8, DI+>DI-) must agree for Bull/Bear. Default 3.")

vixLowTh   = input.float(16, "VIX Low  → Debit only",            step=0.1, group="VIX Thresholds")
vixICLow   = input.float(16, "VIX IC Low",                        step=0.1, group="VIX Thresholds")
vixICHigh  = input.float(19, "VIX IC High",                       step=0.1, group="VIX Thresholds")
vixIBFLow  = input.float(19, "VIX IBF Low  → Iron Butterfly",     step=0.1, group="VIX Thresholds")
vixIBFHigh = input.float(23, "VIX IBF High → Iron Butterfly cap", step=0.1, group="VIX Thresholds")
vixCSMid   = input.float(18, "VIX Mid  → CS (ADX required)",      step=0.1, group="VIX Thresholds")
vixCSHigh  = input.float(19, "VIX High → CS (full size)",         step=0.1, group="VIX Thresholds")

dteCreditSpread = input.int(0,  "DTE — Credit Spreads (0 DTE)",   minval=0, maxval=10, group="DTE Guidance")
dteIronWings    = input.int(5,  "DTE — IC / IBF (3–7 DTE)",        minval=1, maxval=14, group="DTE Guidance")
dteDebit        = input.int(14, "DTE — Debit Spreads (14–21 DTE)", minval=7, maxval=45, group="DTE Guidance")

useIronCondor    = input.bool(true, "Allow Iron Condor",                           group="Options")
useIronButterfly = input.bool(true, "Allow Iron Butterfly",                        group="Options")
waitBars         = input.int(2,     "Bars to wait after RTH open", minval=0, maxval=10, group="Options")
use60mBias       = input.bool(true, "Use 60m as primary trend when TFs disagree",  group="Options")

// Alert timing — clock-based, not bar-count dependent
alert630         = input.bool(true,  "Alert at 6:30 AM PT open (fixed)",           group="Alerts")
alert700         = input.bool(true,  "Alert at 7:00 AM PT (optional)",             group="Alerts")

// ═══════════════════════════════════════════════════════════
// SESSION / TIME
// PT = UTC-7 (PDT). 6:30 AM PT = 13:30 UTC. 7:00 AM PT = 14:00 UTC.
// hour() and minute() in Pine use exchange timezone by default.
// For US equities: exchange TZ = America/New_York (ET).
// 6:30 AM PT = 9:30 AM ET. 7:00 AM PT = 10:00 AM ET.
// ═══════════════════════════════════════════════════════════

isNewDay  = ta.change(time("D")) != 0
inSession = session.ismarket

// Use exchange time (ET for US equities)
h = hour(time, "America/New_York")
m = minute(time, "America/New_York")

// 9:30 AM ET = first bar of RTH (6:30 AM PT)
is630Bar = inSession and barstate.isconfirmed and h == 9  and m == 30
// 10:00 AM ET (7:00 AM PT)
is700Bar = inSession and barstate.isconfirmed and h == 10 and m == 0

var int rthBarCount = 0
if isNewDay
    rthBarCount := 0
if inSession and barstate.isnew
    rthBarCount += 1

// ═══════════════════════════════════════════════════════════
// 5m — MACD, EMA 8, DI
// ═══════════════════════════════════════════════════════════

[macd5, signal5, _]      = request.security(syminfo.tickerid, "5",  ta.macd(close, fastLen, slowLen, sigLen))
ema5                     = request.security(syminfo.tickerid, "5",  ta.ema(close, emaLen))
tf5Close                 = request.security(syminfo.tickerid, "5",  close)
[dip5, dim5, _adx5]      = request.security(syminfo.tickerid, "5",  ta.dmi(adxLen, adxLen))

// ═══════════════════════════════════════════════════════════
// 15m — MACD, EMA 8, DI
// ═══════════════════════════════════════════════════════════

[macd15, signal15, _]    = request.security(syminfo.tickerid, "15", ta.macd(close, fastLen, slowLen, sigLen))
ema15                    = request.security(syminfo.tickerid, "15", ta.ema(close, emaLen))
tf15Close                = request.security(syminfo.tickerid, "15", close)
[dip15, dim15, _adx15]   = request.security(syminfo.tickerid, "15", ta.dmi(adxLen, adxLen))

// ═══════════════════════════════════════════════════════════
// 60m — MACD, EMA 8, DI
// ═══════════════════════════════════════════════════════════

[macd60, signal60, _]    = request.security(syminfo.tickerid, "60", ta.macd(close, fastLen, slowLen, sigLen))
ema60                    = request.security(syminfo.tickerid, "60", ta.ema(close, emaLen))
tf60Close                = request.security(syminfo.tickerid, "60", close)
[dip60, dim60, adxVal]   = ta.dmi(adxLen, adxLen)

// ═══════════════════════════════════════════════════════════
// SCORE-BASED TF STATE
// 4 signals per TF: MACD>0, MACD>Signal, Close>EMA8, DI+>DI-
// Bull if bullScore >= scoreTh, Bear if bearScore >= scoreTh
// Neutral if neither threshold is met
// ═══════════════════════════════════════════════════════════

f_tfScore(_macd, _signal, _close, _ema, _dip, _dim) =>
    bullPts = (_macd > 0 ? 1 : 0) + (_macd > _signal ? 1 : 0) + (_close > _ema ? 1 : 0) + (_dip > _dim ? 1 : 0)
    bearPts = (_macd < 0 ? 1 : 0) + (_macd < _signal ? 1 : 0) + (_close < _ema ? 1 : 0) + (_dim > _dip ? 1 : 0)
    bullPts >= scoreTh ? 1 : bearPts >= scoreTh ? -1 : 0

tf5State  = f_tfScore(macd5,  signal5,  tf5Close,  ema5,  dip5,  dim5)
tf15State = f_tfScore(macd15, signal15, tf15Close, ema15, dip15, dim15)
tf60State = f_tfScore(macd60, signal60, tf60Close, ema60, dip60, dim60)

// ═══════════════════════════════════════════════════════════
// EMA 8 POSITION — above / at / below (±0.05%)
// ═══════════════════════════════════════════════════════════

f_emaPos(_close, _ema) =>
    diff = (_close - _ema) / _ema * 100
    diff > 0.05 ? 1 : diff < -0.05 ? -1 : 0

ema5Pos  = f_emaPos(tf5Close,  ema5)
ema15Pos = f_emaPos(tf15Close, ema15)
ema60Pos = f_emaPos(tf60Close, ema60)

f_emaPosText(_pos) =>
    _pos == 1 ? "↑ EMA 8" : _pos == -1 ? "↓ EMA 8" : "@ EMA 8"

// ═══════════════════════════════════════════════════════════
// CONFIRMED TREND STATE — 60m anchored, 2-bar confirmation
// ═══════════════════════════════════════════════════════════

rawState = tf60State == 1  and tf15State == 1  ?  1 :
           tf60State == -1 and tf15State == -1 ? -1 :
           use60mBias and tf60State != 0        ? tf60State : 0

var int trendState   = 0
var int rawStatePrev = 0
var int sameCount    = 0

if barstate.isnew
    if rawState == rawStatePrev
        sameCount += 1
    else
        sameCount    := 1
        rawStatePrev := rawState
    if sameCount >= 2
        trendState := rawState

// ═══════════════════════════════════════════════════════════
// ADX — TREND STRENGTH (chart timeframe)
// ═══════════════════════════════════════════════════════════

[diplus, diminus, adxChart] = ta.dmi(adxLen, adxLen)
bool adxTrending = adxChart >= adxTrendTh
int  adxBias     = diplus > diminus ? 1 : diplus < diminus ? -1 : 0

// ═══════════════════════════════════════════════════════════
// VIX — OPTIONS REGIME (15m bars)
// ═══════════════════════════════════════════════════════════

vixClose = request.security("TVC:VIX", "15", close)

// ═══════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════

f_csAllowed(_vix, _adxTrending) =>
    _vix >= vixCSHigh or (_vix >= vixCSMid and _adxTrending)

f_csLabel(_vix) =>
    _vix >= vixCSHigh ? "" : " (reduced size)"

f_dteTag(_dte) =>
    _dte == 0 ? " [0 DTE — same day]" : " [" + str.tostring(_dte) + " DTE]"

f_trendText(_ts) =>
    _ts == 1 ? "Bull" : _ts == -1 ? "Bear" : "Neutral"

// ═══════════════════════════════════════════════════════════
// STRATEGY PICKER
// ═══════════════════════════════════════════════════════════

var string strategy    = "Pause for reckoning and coffee"
var string trendText   = "Neutral"
var string oldStrategy = strategy

if barstate.isconfirmed
    trendText   := f_trendText(trendState)
    oldStrategy := strategy

    waitActive = rthBarCount <= waitBars

    if waitActive or not inSession
        strategy := "Pause for reckoning and coffee"
    else
        effectiveTrend = trendState != 0 ? trendState :
                         adxTrending     ? adxBias    : 0

        csOk    = f_csAllowed(vixClose, adxTrending)
        csLabel = f_csLabel(vixClose)
        dteCS   = f_dteTag(dteCreditSpread)
        dteIW   = f_dteTag(dteIronWings)
        dteDbt  = f_dteTag(dteDebit)

        // ── Credit Spreads ──────────────────────────────────
        if effectiveTrend == 1 and adxTrending and csOk
            strategy := "Bull Put Credit Spread (PCS)" + csLabel + dteCS
        else if effectiveTrend == -1 and adxTrending and csOk
            strategy := "Bear Call Credit Spread (CCS)" + csLabel + dteCS

        // ── Neutral / Range-bound ────────────────────────────
        else if effectiveTrend == 0
            if vixClose < vixLowTh
                strategy := adxBias == 1  ? "Bull Call Debit Spread" + dteDbt :
                             adxBias == -1 ? "Bear Put Debit Spread"  + dteDbt :
                             "Debit Spread (wait for direction)" + dteDbt
            else if useIronButterfly and not adxTrending and vixClose >= vixIBFLow and vixClose <= vixIBFHigh
                strategy := "Neutral — Iron Butterfly" + dteIW
            else if useIronCondor and not adxTrending and vixClose >= vixICLow and vixClose <= vixICHigh
                strategy := "Neutral — Iron Condor" + dteIW
            else if vixClose > vixIBFHigh and not adxTrending
                strategy := "Pause for reckoning and coffee"
            else
                strategy := "Pause for reckoning and coffee"

        // ── Trending but VIX below CS floor → directional debit
        else if effectiveTrend == 1
            strategy := adxTrending ? "Bull Call Debit Spread" + dteDbt : "Bull Call Debit Spread (weak)" + dteDbt
        else if effectiveTrend == -1
            strategy := adxTrending ? "Bear Put Debit Spread"  + dteDbt : "Bear Put Debit Spread (weak)"  + dteDbt

// ═══════════════════════════════════════════════════════════
// PLOTTING
// ═══════════════════════════════════════════════════════════

plot(trendState,   title="TrendState (1=Bull,-1=Bear,0=Neutral)", color=color.new(color.blue, 0))
plot(adxChart,     title="ADX (trend strength)",                  color=color.orange)
hline(adxTrendTh,  "ADX Threshold", color=color.new(color.orange, 70))

// ═══════════════════════════════════════════════════════════
// COLOR PALETTE
// Opacity ladder: TF rows 50% → Trend 35% → Strategy 20%
// ═══════════════════════════════════════════════════════════

bullBg      = color.new(#388E3C, 50)
bearBg      = color.new(#D32F2F, 50)
neutBg      = color.new(#546E7A, 50)
trendBullBg = color.new(#388E3C, 35)
trendBearBg = color.new(#D32F2F, 35)
trendNeutBg = color.new(#546E7A, 35)
stratBullBg = color.new(#388E3C, 20)
stratBearBg = color.new(#D32F2F, 20)
stratNeutBg = color.new(#546E7A, 20)
cellTxt     = color.white
labelBg     = color.black
labelTxt    = color.white

// ═══════════════════════════════════════════════════════════
// TABLE — 6 rows: 0=spacer 1=5m 2=15m 3=60m 4=Trend 5=Strategy
// Position: top-right
// ═══════════════════════════════════════════════════════════

var table t = table.new(position.top_right, 3, 6, border_width=1)

if barstate.islast
    tf5Txt  = tf5State  == 1 ? "Bull ▲" : tf5State  == -1 ? "Bear ▼" : "Neutral"
    tf15Txt = tf15State == 1 ? "Bull ▲" : tf15State == -1 ? "Bear ▼" : "Neutral"
    tf60Txt = tf60State == 1 ? "Bull ▲" : tf60State == -1 ? "Bear ▼" : "Neutral"

    bg5  = tf5State  == 1 ? bullBg : tf5State  == -1 ? bearBg : neutBg
    bg15 = tf15State == 1 ? bullBg : tf15State == -1 ? bearBg : neutBg
    bg60 = tf60State == 1 ? bullBg : tf60State == -1 ? bearBg : neutBg

    trendBg = trendState == 1 ? trendBullBg : trendState == -1 ? trendBearBg : trendNeutBg
    stratBg = trendState == 1 ? stratBullBg : trendState == -1 ? stratBearBg : stratNeutBg

    adxStr = "ADX " + str.tostring(adxChart, "#.0") + (adxTrending ? " 🔥" : " –") +
             "  DI+:" + str.tostring(diplus, "#.0") + " DI-:" + str.tostring(diminus, "#.0")
    vixStr = "VIX " + str.tostring(vixClose, "#.00")

    // Row 0 — spacer
    table.cell(t, 0, 0, "", bgcolor=color.new(color.black, 90), text_size=size.tiny)
    table.cell(t, 1, 0, "", bgcolor=color.new(color.black, 90), text_size=size.tiny)
    table.cell(t, 2, 0, "", bgcolor=color.new(color.black, 90), text_size=size.tiny)

    // Row 1 — 5m
    table.cell(t, 0, 1, "5m",    text_color=labelTxt, bgcolor=labelBg, text_size=size.small)
    table.cell(t, 1, 1, tf5Txt,  text_color=cellTxt,  bgcolor=bg5,     text_size=size.small)
    table.cell(t, 2, 1, f_emaPosText(ema5Pos),  text_color=cellTxt, bgcolor=bg5,  text_size=size.small)

    // Row 2 — 15m
    table.cell(t, 0, 2, "15m",   text_color=labelTxt, bgcolor=labelBg, text_size=size.small)
    table.cell(t, 1, 2, tf15Txt, text_color=cellTxt,  bgcolor=bg15,    text_size=size.small)
    table.cell(t, 2, 2, f_emaPosText(ema15Pos), text_color=cellTxt, bgcolor=bg15, text_size=size.small)

    // Row 3 — 60m
    table.cell(t, 0, 3, "60m",   text_color=labelTxt, bgcolor=labelBg, text_size=size.small)
    table.cell(t, 1, 3, tf60Txt, text_color=cellTxt,  bgcolor=bg60,    text_size=size.small)
    table.cell(t, 2, 3, f_emaPosText(ema60Pos), text_color=cellTxt, bgcolor=bg60, text_size=size.small)

    // Row 4 — Trend
    table.cell(t, 0, 4, "Trend",   text_color=labelTxt,     bgcolor=labelBg, text_size=size.small)
    table.cell(t, 1, 4, trendText, text_color=cellTxt,       bgcolor=trendBg, text_size=size.small)
    table.cell(t, 2, 4, adxStr,    text_color=color.orange,  bgcolor=trendBg, text_size=size.small)

    // Row 5 — Strategy
    table.cell(t, 0, 5, "Strategy", text_color=labelTxt, bgcolor=labelBg, text_size=size.small)
    table.cell(t, 1, 5, strategy,   text_color=cellTxt,  bgcolor=stratBg, text_size=size.small)
    table.cell(t, 2, 5, vixStr,     text_color=cellTxt,  bgcolor=stratBg, text_size=size.small)

// ═══════════════════════════════════════════════════════════
// ALERTS
// ─────────────────────────────────────────────────────────
// IMPORTANT — Webhook / Discord setup:
//   In TradingView alert dialog → Message tab → leave BLANK.
//   TradingView will then forward the alert() text below as-is.
//   If the Message field has any text, it overrides alert() output
//   and causes 400 Bad Request or "sys" prefix bugs.
// ─────────────────────────────────────────────────────────
// Four triggers:
//   1. 6:30 AM PT (9:30 AM ET) — open snapshot, always fires if alert630=true
//   2. 7:00 AM PT (10:00 AM ET) — follow-up snapshot, fires if alert700=true
//   3. Strategy changed — any confirmed bar
//   4. Trend changed — any confirmed bar
// ═══════════════════════════════════════════════════════════

string strategyPrev  = oldStrategy
bool   strategyChanged = strategy != strategyPrev
int    trendPrev       = nz(trendState[1], 0)
bool   trendChanged    = trendState != trendPrev

// 6:30 AM PT open snapshot (fixed, always on)
if alert630 and is630Bar
    alert("SP | " + syminfo.ticker + " | OPEN 6:30AM | Trend:" + trendText + " | " + strategy + " | VIX:" + str.tostring(vixClose, "#.00") + " | ADX:" + str.tostring(adxChart, "#.0"), alert.freq_once_per_bar_close)

// 7:00 AM PT follow-up (optional, default on)
if alert700 and is700Bar
    alert("SP | " + syminfo.ticker + " | CHECK 7:00AM | Trend:" + trendText + " | " + strategy + " | VIX:" + str.tostring(vixClose, "#.00") + " | ADX:" + str.tostring(adxChart, "#.0"), alert.freq_once_per_bar_close)

// Strategy changed
if barstate.isconfirmed and strategyChanged
    alert("SP | " + syminfo.ticker + " | STRATEGY | " + strategyPrev + " → " + strategy + " | VIX:" + str.tostring(vixClose, "#.00") + " | ADX:" + str.tostring(adxChart, "#.0"), alert.freq_once_per_bar_close)

// Trend changed
if barstate.isconfirmed and trendChanged
    alert("SP | " + syminfo.ticker + " | TREND | " + f_trendText(trendPrev) + " → " + trendText + " | " + strategy + " | ADX:" + str.tostring(adxChart, "#.0"), alert.freq_once_per_bar_close)
