// © Hin + Claude
// Strategy Picker v1.3 — Fixed Neutral/Pause bug, added ADX trend fallback,
// added 60m TF bias as primary trend signal, expanded table with TF detail.

//@version=6
indicator("Strategy Picker v1.3", overlay=false, max_lines_count=200, max_labels_count=200)


//===== INPUTS =====//
fastLen    = input.int(12,  "MACD Fast Length",   minval=1,   group="MACD / EMA")
slowLen    = input.int(26,  "MACD Slow Length",   minval=1,   group="MACD / EMA")
sigLen     = input.int(9,   "MACD Signal Length", minval=1,   group="MACD / EMA")
emaLen     = input.int(8,   "EMA Length",         minval=1,   group="MACD / EMA")

adxLen     = input.int(14,  "ADX Length",         minval=1,   group="ADX")
adxTrendTh = input.float(20,"ADX Trend Threshold",            group="ADX")

vixLowTh   = input.float(16,"VIX Low (Debit)",    step=0.1,  group="VIX Thresholds")
vixICLow   = input.float(16,"VIX IC Low",         step=0.1,  group="VIX Thresholds")
vixICHigh  = input.float(19,"VIX IC High",        step=0.1,  group="VIX Thresholds")
vixCSHigh  = input.float(19,"VIX CS Threshold",   step=0.1,  group="VIX Thresholds")

useIronCondor = input.bool(true,  "Allow Iron Condor when Neutral", group="Options")
skipWait      = input.bool(false, "Skip wait period at open?",      group="Options")
waitBars      = input.int(2,      "Bars to wait after RTH open", minval=0, maxval=10, group="Options")

// NEW: 60m bias as primary trend signal when 15m/60m disagree
use60mBias    = input.bool(true,  "Use 60m as primary trend when TFs disagree", group="Options")


//===== TIME INFO (ASSUMES US RTH 09:30–16:00 ET) =====//
isNewDay = ta.change(time("D")) != 0
var int rthBarCount = 0
inSession = session.ismarket

if isNewDay
    rthBarCount := 0
if inSession and barstate.isnew
    rthBarCount += 1


//===== 15m MACD & EMA =====//
[macd15, signal15, _] = ta.macd(close, fastLen, slowLen, sigLen)
ema15 = ta.ema(close, emaLen)


//===== 60m MACD & EMA via request.security =====//
[macd60, signal60, _] = request.security(syminfo.tickerid, "60", ta.macd(close, fastLen, slowLen, sigLen))
ema60     = request.security(syminfo.tickerid, "60", ta.ema(close, emaLen))
tf60Close = request.security(syminfo.tickerid, "60", close)


//===== Helper: bull/bear/neutral per TF =====//
f_tfState(_macd, _signal, _close, _ema) =>
    bull = _macd > 0 and _macd > _signal and _close > _ema
    bear = _macd < 0 and _macd < _signal and _close < _ema
    bull ? 1 : bear ? -1 : 0

tf15State = f_tfState(macd15, signal15, close,     ema15)
tf60State = f_tfState(macd60, signal60, tf60Close, ema60)


//===== Raw combined state =====//
// FIX: when TFs disagree and use60mBias=true, trust the 60m direction
rawState = tf60State == 1  and tf15State == 1  ?  1 :
           tf60State == -1 and tf15State == -1 ? -1 :
           use60mBias and tf60State != 0        ? tf60State : 0


//===== 2-BAR CONFIRMED TRENDSTATE =====//
var int trendState   = 0
var int rawStatePrev = 0
var int sameCount    = 0

if barstate.isnew
    if rawState == rawStatePrev
        sameCount += 1
    else
        sameCount    := 1
        rawStatePrev := rawState
    if sameCount >= 2
        trendState := rawState


//===== ADX (15m) =====//
[diplus, diminus, adxVal] = ta.dmi(adxLen, adxLen)
bool adxTrending = adxVal >= adxTrendTh

// ADX-based directional bias (DI+/DI- shows which way ADX is trending)
// FIX: use DI+/DI- to determine direction when trendState is stuck at 0
int adxBias = diplus > diminus ? 1 : diplus < diminus ? -1 : 0


//===== VIX (15m close) =====//
vixClose = request.security("TVC:VIX", "15", close)


//===== STRATEGY PICKER LOGIC =====//

f_trendText(_ts) =>
    _ts == 1 ? "Bull" : _ts == -1 ? "Bear" : "Neutral"

var string strategy   = "Pause for reckoning and coffee"
var string trendText  = "Neutral"
var string oldStrategy = strategy

if barstate.isconfirmed
    trendText   := f_trendText(trendState)
    oldStrategy := strategy

    waitActive = (rthBarCount <= waitBars and not skipWait)

    if waitActive or not inSession
        strategy := "Pause for reckoning and coffee"
    else
        // ── Effective trend: use trendState, fall back to ADX bias if Neutral ──
        // FIX: when MACD/EMA says Neutral but ADX is strong, use DI+/DI- bias
        effectiveTrend = trendState != 0 ? trendState :
                         (adxTrending   ? adxBias    : 0)

        // Strong trend + high VIX → Credit Spreads
        if effectiveTrend == 1 and adxTrending and vixClose >= vixCSHigh
            strategy := "Bull with PCS"
        else if effectiveTrend == -1 and adxTrending and vixClose >= vixCSHigh
            strategy := "Bear with CCS"

        // Neutral (no trend, no ADX bias)
        else if effectiveTrend == 0
            if vixClose < vixLowTh
                strategy := "Debit Trade"
            else if useIronCondor and vixClose >= vixICLow and vixClose <= vixICHigh and not adxTrending
                strategy := "Neutral with Iron Condor"
            else
                strategy := "Pause for reckoning and coffee"

        // Trending but VIX below CS threshold → Debit or trend follow
        else if effectiveTrend == 1
            strategy := adxTrending ? "Bull Debit / Trend Follow" : "Debit Trade"
        else if effectiveTrend == -1
            strategy := adxTrending ? "Bear Debit / Trend Follow" : "Debit Trade"


//===== PLOTTING =====//

plot(trendState,
     title="TrendState (1=Bull, -1=Bear, 0=Neutral)",
     color=color.new(color.blue, 0))

plot(adxVal,
     title="ADX (trend strength)",
     color=color.orange)

hline(adxTrendTh,
      "ADX Threshold (trend vs range)",
      color=color.new(color.orange, 70))

// Table: 4 rows — TF states, trend, ADX/VIX, strategy
var table t = table.new(position.top_left, 3, 4, border_width=1)
if barstate.islast
    // row 0: TF alignment detail (NEW — shows why Neutral or Bull/Bear)
    tf15Txt = tf15State == 1 ? "Bull" : tf15State == -1 ? "Bear" : "Neut"
    tf60Txt = tf60State == 1 ? "Bull" : tf60State == -1 ? "Bear" : "Neut"
    tf15Color = tf15State == 1 ? color.new(color.green, 60) : tf15State == -1 ? color.new(color.red, 60) : color.new(color.gray, 70)
    tf60Color = tf60State == 1 ? color.new(color.green, 60) : tf60State == -1 ? color.new(color.red, 60) : color.new(color.gray, 70)
    table.cell(t, 0, 0, "15m",   text_color=color.white, bgcolor=tf15Color)
    table.cell(t, 1, 0, tf15Txt, text_color=color.white, bgcolor=tf15Color)
    table.cell(t, 2, 0, "DI+:" + str.tostring(diplus, "#.0") + " DI-:" + str.tostring(diminus, "#.0"), text_color=color.white)

    table.cell(t, 0, 1, "60m",   text_color=color.white, bgcolor=tf60Color)
    table.cell(t, 1, 1, tf60Txt, text_color=color.white, bgcolor=tf60Color)
    table.cell(t, 2, 1, "ADX Bias: " + (adxBias == 1 ? "Bull ▲" : adxBias == -1 ? "Bear ▼" : "Flat"), text_color=color.white)

    // row 2: confirmed trend + ADX
    trendBgColor = trendState == 1 ? color.new(color.green, 70) : trendState == -1 ? color.new(color.red, 70) : color.new(color.blue, 70)
    table.cell(t, 0, 2, "Trend",    text_color=color.white, bgcolor=trendBgColor)
    table.cell(t, 1, 2, trendText,  text_color=color.white)
    table.cell(t, 2, 2, "ADX: " + str.tostring(adxVal, format.mintick) + (adxTrending ? " 🔥" : " –"), text_color=color.orange)

    // row 3: strategy + VIX
    table.cell(t, 0, 3, "Strategy", text_color=color.white, bgcolor=color.new(color.green, 70))
    table.cell(t, 1, 3, strategy,   text_color=color.white)
    table.cell(t, 2, 3, "VIX: " + str.tostring(vixClose, format.mintick), text_color=color.white)


//===== ALERTS =====//

string strategyPrev = oldStrategy
strategyChanged = strategy != strategyPrev

alertcondition(strategyChanged,
     title   = "Strategy Changed",
     message = "Strategy Picker: strategy changed")

trendPrev    = nz(trendState[1], 0)
trendChanged = trendState != trendPrev

alertcondition(trendChanged,
     title   = "Trend Change",
     message = "Strategy Picker: trend changed")
